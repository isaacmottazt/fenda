{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login",          "destination": "/index.html" },
    { "source": "/inicio",         "destination": "/player.html" },
    { "source": "/busca",          "destination": "/player.html" },
    { "source": "/biblioteca",     "destination": "/player.html" },
    { "source": "/perfil",         "destination": "/player.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" }
  ],
  "redirects": [
    { "source": "/index.html",          "destination": "/login",   "permanent": true },
    { "source": "/player.html",         "destination": "/inicio",  "permanent": true },
    { "source": "/reset-password.html", "destination": "/reset-password", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-XSS-Protection",      "value": "1; mode=block" }
      ]
    }
  ]
}
