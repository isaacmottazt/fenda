{
  "rewrites": [
    { "source": "/login",          "destination": "/index.html" },
    { "source": "/inicio",         "destination": "/player.html" },
    { "source": "/busca",          "destination": "/player.html" },
    { "source": "/biblioteca",     "destination": "/player.html" },
    { "source": "/perfil",         "destination": "/player.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" }
  ],
  "redirects": [
    { "source": "/player", "destination": "/player.html", "permanent": false },
    { "source": "/index",  "destination": "/index.html",  "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection",      "value": "1; mode=block" }
      ]
    }
  ]
}

